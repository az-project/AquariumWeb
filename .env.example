APP_USERNAME=admin
APP_PASSWORD=aquarium
SESSION_SECRET=replace-with-at-least-32-characters

# file | supabase. If omitted, Supabase is used only when the URL and service key are present.
STORAGE_DRIVER=file

# Required when STORAGE_DRIVER=supabase.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STATE_KEY=default

# Optional. Required for protected remote MCP access when set.
REEFLOG_MCP_TOKEN=replace-with-a-long-random-token
REEFLOG_MCP_ALLOW_ORIGIN=*
